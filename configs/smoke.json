{
  "experiment": "smoke",
  "protocols": ["shye", "fixed_path_onion", "random_walk", "flooding"],
  "seeds": [1],
  "topologies": ["random"],
  "network": {
    "nodeCounts": [30],
    "averageDegrees": [4],
    "baseDelayMs": 20,
    "jitterMs": 10,
    "lossProbabilities": [0.0]
  },
  "traffic": {
    "simulationDurationMs": 5000,
    "maxTailMs": 5000,
    "lambdaMsg": 0.5,
    "lambdaCover": 0.01,
    "stateSampleIntervalMs": 2500,
    "realPacketBytes": 1024,
    "coverPacketBytes": 256,
    "maxEvents": 200000
  },
  "shye": {
    "ttlValues": [5],
    "floodDepth": 3,
    "heartbeatMs": 1000,
    "tauSettleMs": 200,
    "overlapWindowMs": 300,
    "commitRevealDelayMs": 100,
    "witnessF": 1,
    "rendezvousF": 1
  },
  "adversary": {
    "alphaValues": [0.0],
    "observerModes": ["local"],
    "identityMultiplier": 1.0,
    "grindingAttempts": 1,
    "maliciousDropProbability": 0.0,
    "maliciousDelayMs": 0.0
  },
  "ablation": {
    "disableCommitReveal": false,
    "disableDedup": false,
    "disableWinnerCert": false,
    "disableLinkProof": false,
    "disableRerandomization": false,
    "enableStableRouteTag": false,
    "disableTtl": false
  },
  "cryptoCost": {
    "winnerCertVerifyMs": 0.2,
    "winnerCertBytes": 96,
    "linkProofVerifyMs": 1.0,
    "linkProofBytes": 512,
    "thresholdDecryptMs": 2.0,
    "thresholdDecryptBytes": 256,
    "forwarderSignatureBytes": 64
  },
  "output": {
    "directory": "results/raw",
    "writeEvents": true,
    "writeNodeState": true
  }
}
